# ─────────────────────────────────────────────────────────────────────────────
# MOVO Backend — Environment Variables
# Copy to .env and populate with real values (never commit the real .env)
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase PostgreSQL ───────────────────────────────────────────────────────
# Find in Supabase → Project Settings → Database → Connection string (JDBC)
SUPABASE_DB_URL=jdbc:postgresql://db.YOUR_PROJECT.supabase.co:5432/postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD

# ── Supabase Auth ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET   # Project Settings → API → JWT Secret

# ── Grok (xAI) API ───────────────────────────────────────────────────────────
GROK_API_KEY=xai-YOUR_GROK_API_KEY             # console.x.ai

# ── Internal JWT (for session tokens issued by your backend, optional) ────────
JWT_SECRET=at_least_32_characters_random_secret_here
